# Client-level .easignore

# Dependencies — EAS installs fresh
node_modules/

# Expo cache
.expo/

# Build outputs
dist/
web-build/
android/
ios/

# Test files
__tests__/
coverage/
jest.config.js

# Docs / markdown (not needed at runtime)
*.md
API_DOCUMENTATION.md
DATA-MODELS.md
README.md

# Secrets
.env
.env.local
.env*.local

# Signing artifacts (managed by EAS)
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Misc
*.orig.*
*.tsbuildinfo
npm-debug.*
.DS_Store
Thumbs.db
