{
  "expo": {
    "name": "Tanak Prabha",
    "slug": "tanak-prabha",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "tanakprabha",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tanakprabha.app",
      "buildNumber": "2"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/icon.png",
        "backgroundColor": "#fcf7f8"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.tanakprabha.app",
      "versionCode": 2
    },
    "web": {
      "bundler": "metro",
      "favicon": "./src/assets/images/icon.png"
    },
    "notification": {
      "icon": "./src/assets/images/notification-icon.png",
      "color": "#16A34A"
    },
    "plugins": [
      "./plugins/withAndroidPackagingOptions",
      "./plugins/withGradleNetworkTimeout",
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Tanak-Prabha to access your photos to upload a profile picture.",
          "cameraPermission": "Allow Tanak-Prabha to use your camera."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1B4332",
          "dark": {
            "backgroundColor": "#1B4332"
          }
        }
      ],
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/notification-icon.png",
          "color": "#16A34A",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0cb05082-c3de-4ef4-9414-16f90f7e90fb"
      }
    },
    "owner": "cr-8"
  }
}