{
  "expo": {
    "name": "Tanak Prabha",
    "slug": "tanak-prabha",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "tanakprabha",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tanakprabha.app",
      "buildNumber": "2"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "${EXPO_PUBLIC_GOOGLE_MAPS_API_KEY}"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/icon.png",
        "backgroundColor": "#fcf7f8"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.tanakprabha.app",
      "versionCode": 2,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "tanakprabha",
              "host": "attendance"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./src/assets/images/icon.png"
    },
    "notification": {
      "icon": "./src/assets/images/notification-icon.png",
      "color": "#16A34A"
    },
    "plugins": [
      "./plugins/withAndroidPackagingOptions",
      "./plugins/withGradleNetworkTimeout",
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Tanak-Prabha to access your photos to upload a profile picture.",
          "cameraPermission": "Allow Tanak-Prabha to use your camera."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Tanak-Prabha to use your camera to scan attendance QR codes."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1B4332",
          "dark": {
            "backgroundColor": "#1B4332"
          }
        }
      ],
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/notification-icon.png",
          "color": "#16A34A",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "44ac0997-c234-4a0c-82d4-c6eaa4052709"
      },
      "attendanceFallbackUrl": "https://play.google.com/store/apps/details?id=com.tanakprabha.app"
    }
  }
}
