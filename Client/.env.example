# ===========================================
# Tanak Prabha Client Environment Configuration
# ===========================================
# Copy this file to .env and update the values

# ===========================================
# API Configuration
# ===========================================

# For local development with emulator:
EXPO_PUBLIC_API_URL=http://localhost:5000/api

# For testing on physical device (Android), use your machine's local IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.XXX:5000/api

# For Android emulator, use 10.0.2.2 to access host machine:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api

# For iOS simulator, localhost works fine:
# EXPO_PUBLIC_API_URL=http://localhost:5000/api

# ===========================================
# PRODUCTION DEPLOYMENT
# ===========================================
# For production, replace with your deployed backend URL:
# EXPO_PUBLIC_API_URL=https://api.your-domain.com/api

# ===========================================
# Cloudinary Configuration (Optional - for direct uploads)
# ===========================================
# Note: Client uploads go through backend API endpoints
# which handle Cloudinary integration automatically
# EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ===========================================
# App Configuration
# ===========================================
# App name and version (used in API headers)
EXPO_PUBLIC_APP_NAME=TanakPrabha
EXPO_PUBLIC_APP_VERSION=1.0.0

# ===========================================
# Google Maps Configuration
# ===========================================
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
