# ===========================================
# Server Configuration
# ===========================================
NODE_ENV=development
PORT=5000

# ===========================================
# Database Configuration (Supabase PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres
SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ===========================================
# Authentication (JWT)
# ===========================================
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# ===========================================
# Dashboard API Key (Admin Dashboard Access)
# ===========================================
# This key allows the admin dashboard to access protected routes
DASHBOARD_API_KEY=tanak-prabha-dashboard-secret-key-2024

# ===========================================
# CORS Configuration
# ===========================================
# For local development:
CORS_ORIGIN=http://localhost:3000,http://localhost:8081,exp://localhost:8081
# For production (add your dashboard and app URLs):
# CORS_ORIGIN=https://dashboard.your-domain.com,https://app.your-domain.com

# ===========================================
# Production URL (for deployment)
# ===========================================
# Set this to your production backend URL when deploying
# PRODUCTION_URL=https://api.your-domain.com

# ===========================================
# OTP Configuration (Development)
# ===========================================
# In development, OTPs are returned in the response
# In production, integrate with SMS gateway
SMS_GATEWAY_API_KEY=your_sms_gateway_key
SMS_GATEWAY_URL=https://api.your-sms-provider.com/send

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# Email Configuration (Ethereal for development)
# ===========================================
# Sign up at https://ethereal.email to get test credentials
# Leave EMAIL_USER and EMAIL_PASS empty to auto-create a random Ethereal account
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=your_ethereal_user@ethereal.email
EMAIL_PASS=your_ethereal_password
EMAIL_FROM=noreply@tanakprabha.in
# OTP emails will be sent to this address (set to your Ethereal user to see them)
OTP_TEST_EMAIL=your_ethereal_user@ethereal.email

# Optional: email timeouts (milliseconds). Short values prevent SMTP issues from blocking API responses.
# EMAIL_CONN_TIMEOUT=5000
# EMAIL_SEND_TIMEOUT=5000
